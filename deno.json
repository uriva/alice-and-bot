{
  "tasks": {
    "build-landing": "deno run -A --node-modules-dir=auto npm:vite build",
    "landing": "deno run -A --node-modules-dir=auto npm:vite",
    "widget": "cd widget && deno run -A --node-modules-dir=auto npm:vite build --config vite.config.ts",
    "chatgpt-style": "cd example; deno run -A --node-modules-dir=auto npm:vite",
    "build": "deno run -A --node-modules-dir=auto npm:vite build",
    "check": "deno fmt --check && deno lint && deno check *.ts backend/**/*.ts example/**/*.ts landing/**/*.ts lit/**/*.ts protocol/**/*.ts widget/**/*.ts",
    "test:e2e": "cd e2e && deno run -A --node-modules-dir=auto npm:playwright test"
  },
  "githooks": {
    "$schema": "https://deno.land/x/githooks/schema.json",
    "pre-commit": "check"
  },
  "imports": {
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "@std/testing/time": "jsr:@std/testing@^1.0.17/time",
    "@uri/crypto-utils": "jsr:@uri/crypto-utils@^0.0.2",
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^1.0.5",
    "@google-cloud/storage": "npm:@google-cloud/storage@7.16.0",
    "@instantdb/admin": "npm:@instantdb/admin@0.22.174",
    "@instantdb/core": "npm:@instantdb/core@0.22.174",
    "@std/assert": "jsr:@std/assert@1",
    "@uri/gamla": "jsr:@uri/gamla@0.0.14",
    "buffer": "npm:buffer@6.0.3",
    "emoji-picker-element": "npm:emoji-picker-element@^1.29.1",
    "highlight.js": "npm:highlight.js@^11.11.1",
    "@lit/react": "npm:@lit/react@1.0.8",
    "lit": "npm:lit@3.3.2",
    "marked": "npm:marked@15.0.7",
    "highlight.js/lib/core": "npm:highlight.js@^11.11.1/lib/core",
    "highlight.js/lib/languages/typescript": "npm:highlight.js@^11.11.1/lib/languages/typescript",
    "highlight.js/styles/github-dark.css": "npm:highlight.js@^11.11.1/styles/github-dark.css",
    "posthog-js": "npm:posthog-js@1.313.0",
    "qrcode": "npm:qrcode@1.5.4",
    "react": "npm:react@19.1.0",
    "safe-stable-stringify": "npm:safe-stable-stringify@2.5.0",
    "typed-api": "jsr:@uri/typed-api@0.0.10",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@4.2.1",
    "tailwindcss": "npm:tailwindcss@4.2.1",
    "vite": "npm:vite@^7.0.2",
    "web-push": "npm:web-push@3.6.7",
    "zod": "npm:zod@3.25.57"
  },
  "unstable": [
    "cron",
    "kv"
  ],
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "dom.asynciterable",
      "esnext",
      "deno.ns",
      "deno.unstable"
    ],
    "types": [
      "./landing/src/vite-env.d.ts"
    ]
  },
  "lint": {
    "exclude": ["opencode-plugin/plugin.js"]
  },
  "license": "MIT",
  "name": "@alice-and-bot/core",
  "version": "0.0.286",
  "exports": {
    ".": "./mod.ts",
    "./components": "./components.ts"
  },
  "deploy": {
    "org": "uriva",
    "app": "alice-and-bot"
  }
}
