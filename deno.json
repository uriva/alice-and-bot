{
  "tasks": {
    "build-landing": "mkdir -p landing/node_modules/vite-prerender-plugin && deno run -A --node-modules-dir=auto npm:vite build",
    "landing": "deno run -A --node-modules-dir=auto npm:vite",
    "widget": "cd widget && deno run -A --node-modules-dir=auto npm:vite build --config vite.config.ts",
    "dev": "cd clients/react; deno run -A --node-modules-dir=auto npm:vite",
    "example": "cd example; deno run -A --node-modules-dir=auto npm:vite",
    "build": "deno run -A --node-modules-dir=auto npm:vite build",
    "check": "deno fmt --check && deno lint && deno check *.ts backend/**/*.ts clients/**/*.ts clients/**/*.tsx example/**/*.tsx landing/**/*.ts landing/**/*.tsx protocol/**/*.ts widget/**/*.ts widget/**/*.tsx"
  },
  "githooks": {
    "$schema": "https://deno.land/x/githooks/schema.json",
    "pre-commit": "check"
  },
  "imports": {
    "@uri/crypto-utils": "jsr:@uri/crypto-utils@^0.0.2",
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^1.0.5",
    "@google-cloud/storage": "npm:@google-cloud/storage@7.16.0",
    "@instantdb/admin": "npm:@instantdb/admin@0.22.174",
    "@instantdb/core": "npm:@instantdb/core@0.22.174",
    "@instantdb/react": "npm:@instantdb/react@0.22.174",
    "@preact/preset-vite": "npm:@preact/preset-vite@2.10.2",
    "@radix-ui/react-slot": "npm:@radix-ui/react-slot@1.1.2",
    "@preact/signals": "npm:@preact/signals@2.1.1",
    "@std/assert": "jsr:@std/assert@1",
    "@uri/gamla": "jsr:@uri/gamla@0.0.14",
    "buffer": "npm:buffer@6.0.3",
    "highlight.js": "npm:highlight.js@^11.11.1",
    "highlight.js/lib/core": "npm:highlight.js@^11.11.1/lib/core",
    "highlight.js/lib/languages/typescript": "npm:highlight.js@^11.11.1/lib/languages/typescript",
    "highlight.js/styles/github-dark.css": "npm:highlight.js@^11.11.1/styles/github-dark.css",
    "posthog-js": "npm:posthog-js@1.313.0",
    "preact-iso": "npm:preact-iso@2.9.1",
    "preact": "npm:preact@10.26.7",
    "qrcode": "npm:qrcode@1.5.4",
    "preact/hooks": "npm:preact@10.26.7/hooks",
    "preact/jsx-runtime": "npm:preact@10.26.7/jsx-runtime",
    "react-hot-toast": "npm:react-hot-toast@2.5.2",
    "react-icons/fa": "npm:react-icons@5.5.0/fa",
    "react-markdown": "npm:react-markdown@10.1.0",
    "rehype-highlight": "npm:rehype-highlight@^7.0.2",
    "remark-breaks": "npm:remark-breaks@4.0.0",
    "remark-gfm": "npm:remark-gfm@4.0.1",
    "safe-stable-stringify": "npm:safe-stable-stringify@2.5.0",
    "typed-api": "jsr:@uri/typed-api@0.0.10",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@4.2.1",
    "tailwindcss": "npm:tailwindcss@4.2.1",
    "vite-prerender-plugin": "npm:vite-prerender-plugin@0.5.12",
    "vite": "npm:vite@^7.0.2",
    "web-push": "npm:web-push@3.6.7",
    "zod": "npm:zod@3.25.57"
  },
  "unstable": [
    "cron",
    "kv"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "types": [
      "./landing/src/vite-env.d.ts"
    ]
  },
  "lint": {
    "exclude": ["opencode-plugin/plugin.js"]
  },
  "license": "MIT",
  "name": "@alice-and-bot/core",
  "version": "0.0.247",
  "exports": "./mod.ts",
  "deploy": {
    "org": "uriva",
    "app": "alice-and-bot"
  }
}
